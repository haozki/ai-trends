---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="AIBOX - AI 科技导航">
  <main>
    <h1 style="color: var(--cyan); font-size: 3rem; text-align: center; margin-top: 30vh;">
      AIBOX
    </h1>
    <p style="text-align: center; color: var(--text-muted); margin-top: 1rem; font-size: 1.2rem;">
      AI 科技导航站
    </p>
    <nav style="text-align: center; margin-top: 2rem;">
      <a href="/ai-trends/blog/" style="color: var(--cyan); text-decoration: none; font-size: 1.1rem; border: 1px solid var(--cyan); padding: 0.5rem 1.5rem; border-radius: 0.5rem; transition: all 0.2s;">
        查看博客文章 →
      </a>
    </nav>
  </main>
</BaseLayout>

---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getCollection('blog', ({ data }) => {
  return import.meta.env.PROD ? !data.draft : true;
});

const sortedPosts = posts.sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

function formatDate(date: Date) {
  return date.toLocaleDateString('zh-CN', {
    year: 'numeric',
    month: 'long',
    day: 'numeric',
  });
}

const iconColors = [
  { bg: '#fecdd3', color: '#e11d48' },
  { bg: '#bfdbfe', color: '#2563eb' },
  { bg: '#bbf7d0', color: '#16a34a' },
  { bg: '#c7d2fe', color: '#4f46e5' },
];
---

<BaseLayout title="AIBOX - AI 科技导航">
  <main class="courses-section">
    <div class="container">
      <div class="section-header">
        <h1 class="section-title">
          <span class="title-dark">Explore</span>
          <span class="title-green">AI</span>
          <span class="title-dark">World</span>
        </h1>
        <p class="section-subtitle">AI科技领域技术&项目分享</p>
      </div>
      
      <div class="courses-grid">
        {sortedPosts.map((post, index) => (
          <article class="course-card">
            <div class="course-icon" style={`background: ${iconColors[index % iconColors.length].bg}; color: ${iconColors[index % iconColors.length].color};`}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/>
              </svg>
            </div>
            <div class="course-info">
              <h2 class="course-title">
                <a href={`./blog/${post.id}`}>{post.data.title}</a>
              </h2>
              <p class="course-author">by {post.data.author}</p>
              <div class="course-stats">
                <span class="stat">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/>
                  </svg>
                  {post.data.tags.length} tags
                </span>
                <span class="stat">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
                  </svg>
                  {formatDate(post.data.pubDate)}
                </span>
              </div>
            </div>
            <div class="course-rating">
              <svg viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
              </svg>
              <span>{(4.5 + (index % 5) * 0.1).toFixed(1)}</span>
            </div>
          </article>
        ))}
      </div>
      
      {sortedPosts.length === 0 && (
        <div class="empty-state">
          <div class="empty-icon">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m5.231 13.481L15 17.25m-4.5-15H5.625c-.621 0-1.125.504-1.125 1.125v16.5c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9zm3.75 11.625a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
            </svg>
          </div>
          <p>暂无文章</p>
          <p class="empty-hint">敬请期待更多精彩内容</p>
        </div>
      )}
    </div>
  </main>
  
  <footer class="footer">
    <div class="container">
      <div class="footer-content">
        <p class="footer-text">© 2026 AIBOX. 探索AI的未来。</p>
        <div class="footer-links">
          <a href="https://github.com/haozki/ai-trends" target="_blank" rel="noopener noreferrer">GitHub</a>
        </div>
      </div>
    </div>
  </footer>
</BaseLayout>

<style>
  .courses-section {
    padding: 4rem 0 6rem;
    min-height: 100vh;
    background: #f8fafc;
  }
  
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
    width: 100%;
  }
  
  .section-header {
    text-align: left;
    margin-bottom: 3rem;
    padding-left: 0.5rem;
  }
  
  .section-title {
    font-size: clamp(2.5rem, 5vw, 3.5rem);
    font-weight: 900;
    margin-bottom: 0.5rem;
    letter-spacing: -0.03em;
    line-height: 1.2;
    font-family: 'Nunito', sans-serif;
  }
  
  .title-dark {
    color: #1e293b;
  }
  
  .title-green {
    color: #22c55e;
  }
  
  .section-subtitle {
    color: #64748b;
    font-size: 1.1rem;
    font-weight: 400;
  }
  
  .courses-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.25rem;
  }
  
  .course-card {
    background: #ffffff;
    border: 2px solid #1e293b;
    border-radius: 16px;
    padding: 1.25rem;
    display: flex;
    align-items: center;
    gap: 1rem;
    transition: all 0.3s ease;
    cursor: pointer;
    position: relative;
  }
  
  .course-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }
  
  .course-icon {
    width: 56px;
    height: 56px;
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  
  .course-icon svg {
    width: 28px;
    height: 28px;
  }
  
  .course-info {
    flex: 1;
    min-width: 0;
  }
  
  .course-title {
    font-size: 1rem;
    font-weight: 700;
    color: #0f172a;
    margin-bottom: 0.25rem;
    line-height: 1.3;
  }
  
  .course-title a {
    color: inherit;
    text-decoration: none;
  }
  
  .course-title a:hover {
    color: #7c3aed;
  }
  
  .course-author {
    color: #64748b;
    font-size: 0.8rem;
    margin-bottom: 0.5rem;
  }
  
  .course-stats {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
  
  .stat {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
    color: #64748b;
    font-size: 0.75rem;
  }
  
  .stat svg {
    width: 14px;
    height: 14px;
  }
  
  .course-rating {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: #dcfce7;
    color: #16a34a;
    padding: 0.375rem 0.75rem;
    border-radius: 9999px;
    font-size: 0.875rem;
    font-weight: 600;
    flex-shrink: 0;
  }
  
  .course-rating svg {
    width: 14px;
    height: 14px;
  }
  
  .empty-state {
    text-align: center;
    padding: 6rem 2rem;
    color: #64748b;
  }
  
  .empty-icon {
    width: 80px;
    height: 80px;
    margin: 0 auto 2rem;
    color: #94a3b8;
  }
  
  .empty-icon svg {
    width: 100%;
    height: 100%;
  }
  
  .empty-hint {
    margin-top: 0.5rem;
    font-size: 0.9rem;
    color: #94a3b8;
  }
  
  .footer {
    padding: 3rem 0;
    background: #ffffff;
    border-top: 1px solid #e2e8f0;
  }
  
  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }
  
  .footer-text {
    color: #64748b;
    font-size: 0.9rem;
  }
  
  .footer-links {
    display: flex;
    gap: 2rem;
  }
  
  .footer-links a {
    color: #64748b;
    transition: color 0.2s ease;
  }
  
  .footer-links a:hover {
    color: #7c3aed;
  }
  
  @media (max-width: 768px) {
    .courses-section {
      padding: 3rem 0 4rem;
    }
    
    .courses-grid {
      grid-template-columns: 1fr;
    }
    
    .course-card {
      padding: 1rem;
    }
    
    .course-icon {
      width: 48px;
      height: 48px;
    }
    
    .course-icon svg {
      width: 24px;
      height: 24px;
    }
    
    .course-title {
      font-size: 0.9rem;
    }
    
    .course-author {
      font-size: 0.75rem;
    }
    
    .stat {
      font-size: 0.7rem;
    }
    
    .stat svg {
      width: 12px;
      height: 12px;
    }
    
    .course-rating {
      font-size: 0.8rem;
      padding: 0.25rem 0.5rem;
    }
    
    .course-rating svg {
      width: 12px;
      height: 12px;
    }
    
    .footer-content {
      flex-direction: column;
      text-align: center;
    }
  }
</style>

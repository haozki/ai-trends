---
export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <!-- Google Fonts: Nunito + DM Sans -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800;900&family=DM+Sans:wght@400;500;700&display=swap" rel="stylesheet">
  <style is:global>
    :root {
      /* AI科技极简风格配色方案 */
      --primary: #7C3AED; /* 紫色 */
      --primary-light: #A78BFA; /* 浅紫色 */
      --secondary: #06B6D4; /* 青色/霓虹蓝 */
      --secondary-light: #22D3EE; /* 浅青色 */
      --accent: #F43F5E; /* 强调色（可选） */
      --accent-orange: #F97316; /* 橙色强调 */
      --accent-green: #22C55E; /* 绿色强调 */
      
      /* 背景与文字 */
      --bg: #FAF5FF; /* 浅紫色背景 */
      --bg-secondary: #F3E8FF; /* 更浅的紫色背景 */
      --surface: #FFFFFF; /* 卡片背景 */
      --surface-hover: #F8FAFC; /* 悬停背景 */
      --text: #1E1B4B; /* 深紫色文字 */
      --text-muted: #6B7280; /* 灰色文字 */
      --text-light: #9CA3AF; /* 浅灰色文字 */
      
      /* 边框与发光 */
      --border: #E5E7EB; /* 细线边框 */
      --border-light: #F3F4F6; /* 更细的边框 */
      --glow-primary: 0 0 20px rgba(124, 58, 237, 0.3); /* 紫色发光 */
      --glow-secondary: 0 0 20px rgba(6, 182, 212, 0.3); /* 青色发光 */
      --glow-primary-strong: 0 0 30px rgba(124, 58, 237, 0.5); /* 强紫色发光 */
      --glow-secondary-strong: 0 0 30px rgba(6, 182, 212, 0.5); /* 强青色发光 */
      
      /* 渐变 */
      --gradient-primary: linear-gradient(135deg, var(--primary), var(--secondary));
      --gradient-text: linear-gradient(135deg, var(--primary), var(--secondary));
      
      /* 间距与圆角 */
      --radius-sm: 0.375rem;
      --radius-md: 0.5rem;
      --radius-lg: 1rem;
      --radius-xl: 1.5rem;
      --radius-2xl: 1.25rem;
      
      /* 阴影 */
      --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
      --shadow-md: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -1px rgba(0, 0, 0, 0.06);
      --shadow-lg: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05);
      --shadow-xl: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
      --shadow-card: 0 4px 6px -1px rgba(0, 0, 0, 0.1), 0 2px 4px -2px rgba(0, 0, 0, 0.1);
      --shadow-card-hover: 0 20px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
      
      /* 字体 */
      --font-heading: 'Space Grotesk', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'JetBrains Mono', monospace;
    }

    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }

    body {
      font-family: var(--font-body);
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      -moz-osx-font-smoothing: grayscale;
    }
    
    /* 全局链接样式 */
    a {
      color: var(--primary);
      text-decoration: none;
      transition: color 0.2s ease;
    }
    
    a:hover {
      color: var(--secondary);
    }
    
    /* 全局标题样式 */
    h1, h2, h3, h4, h5, h6 {
      font-family: var(--font-heading);
      font-weight: 600;
      line-height: 1.3;
      color: var(--text);
    }
    
    /* 平滑滚动 */
    html {
      scroll-behavior: smooth;
    }
    
    /* 焦点状态 */
    :focus-visible {
      outline: 2px solid var(--secondary);
      outline-offset: 2px;
      border-radius: var(--radius-sm);
    }
    
    /* 减少动画偏好 */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
  </style>
</head>
<body>
  <slot />
</body>
</html>
